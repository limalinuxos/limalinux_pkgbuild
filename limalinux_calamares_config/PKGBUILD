pkgname=limalinux_calamares_config
_pkgname=limalinux_calamares_config
_destname1="/etc"
_destname2="/usr"
_destnamescript="/usr/bin"
pkgver=26.03
pkgrel=05
pkgdesc="calamares config for limalinux"
arch=('any')
url="https://github.com/limalinuxos/${_pkgname}"
license=('GPL3')
makedepends=('git')
depends=()
conflicts=(limalinux_calamares_config_next)
provides=("${pkgname}")
options=(!strip !emptydirs)
source=(${_pkgname}::"git+$url")
sha256sums=('SKIP')
install='readme.install'
package() {
	mkdir -p "${pkgdir}${_destname1}"
	cp -r "${srcdir}/${_pkgname}/${_destname1}"* "${pkgdir}"
	mkdir -p "${pkgdir}${_destname2}"
	cp -r "${srcdir}/${_pkgname}/${_destname2}"* "${pkgdir}"
	mkdir -p "${pkgdir}${_destnamescript}"
	cp -r "${srcdir}/${_pkgname}/etc/calamares/pkgbuild/build_calamares" "${pkgdir}${_destnamescript}"
}
